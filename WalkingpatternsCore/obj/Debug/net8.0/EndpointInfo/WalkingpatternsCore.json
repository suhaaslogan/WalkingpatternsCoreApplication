{
  "openapi": "3.0.1",
  "info": {
    "title": "WalkingpatternsCore",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginApi"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginApi"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginApi"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Client/project/{clientName}": {
      "get": {
        "tags": [
          "Client"
        ],
        "parameters": [
          {
            "name": "clientName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Client/addProject": {
      "post": {
        "tags": [
          "Client"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectVersionDetailsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectVersionDetailsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectVersionDetailsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Home": {
      "get": {
        "tags": [
          "Home"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Home"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientDetailsDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ClientDetailsDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ClientDetailsDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Home/{clientName}": {
      "delete": {
        "tags": [
          "Home"
        ],
        "parameters": [
          {
            "name": "clientName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ClientDetailsDto": {
        "type": "object",
        "properties": {
          "clientName": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginApi": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProjectVersionDetailsDto": {
        "required": [
          "clientId"
        ],
        "type": "object",
        "properties": {
          "projectName": {
            "type": "string",
            "nullable": true
          },
          "projectDate": {
            "type": "string",
            "nullable": true
          },
          "versionNumber": {
            "type": "string",
            "nullable": true
          },
          "clientName": {
            "type": "string",
            "nullable": true
          },
          "clientId": {
            "type": "integer",
            "format": "int32"
          },
          "client": {
            "$ref": "#/components/schemas/ClientDetailsDto"
          }
        },
        "additionalProperties": false
      }
    }
  }
}